{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/nix-guardian.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/nix-format.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/rust-format.sh" }
        ]
      }
    ]
  }
}
